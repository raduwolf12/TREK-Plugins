{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mauriceboe/TREK-Plugins/schema/plugin-entry.schema.json",
  "title": "TREK plugin registry entry",
  "description": "One registry/plugins/<id>.json file. reviewedAt and boundOwner are maintained by CI/publish and may be omitted by submitters.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "author", "description", "repo", "type", "versions"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,39}$",
      "description": "Unique slug. Must equal the filename (without .json)."
    },
    "name": { "type": "string", "minLength": 2, "maxLength": 60 },
    "author": { "type": "string", "minLength": 1, "maxLength": 80 },
    "description": { "type": "string", "minLength": 8, "maxLength": 200 },
    "repo": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$",
      "description": "GitHub owner/name. Source of truth for the plugin code."
    },
    "homepage": { "type": "string", "format": "uri" },
    "tags": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9-]{2,24}$" },
      "maxItems": 8
    },
    "type": { "enum": ["integration", "page", "widget", "trip-page"] },
    "reviewedAt": { "type": ["string", "null"], "format": "date" },
    "boundOwner": { "type": "string" },
    "authorPublicKey": {
      "type": "string",
      "minLength": 40,
      "maxLength": 120,
      "description": "Optional base64 minisign (Ed25519) public key. Stable across versions; TREK pins it on first install (TOFU)."
    },
    "versions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/version" }
    }
  },
  "$defs": {
    "version": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "gitTag", "commitSha", "downloadUrl", "sha256", "minTrekVersion", "size", "apiVersion", "nativeModules"],
      "properties": {
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$" },
        "gitTag": { "type": "string", "minLength": 1 },
        "commitSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "downloadUrl": {
          "type": "string",
          "pattern": "^https://(github\\.com|codeload\\.github\\.com|objects\\.githubusercontent\\.com)/"
        },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "minTrekVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "maxTrekVersion": { "type": ["string", "null"], "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "size": { "type": "integer", "minimum": 1, "maximum": 52428800 },
        "apiVersion": { "type": "integer", "minimum": 1 },
        "nativeModules": {
          "const": false,
          "description": "Native .node binaries are forbidden in v1."
        },
        "signature": {
          "type": "string",
          "minLength": 40,
          "description": "Optional base64 minisign signature over the artifact bytes. Requires authorPublicKey on the entry."
        },
        "publishedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
